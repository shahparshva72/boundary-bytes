{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "singleQuote": true,
  "printWidth": 100,
  "tabWidth": 2,
  "trailingComma": "all",
  "sortPackageJson": false,
  "sortImports": {
    "partitionByNewline": true,
    "newlinesBetween": false
  },
  "ignorePatterns": ["node_modules", ".next", "build", "coverage", "*.csv"]
}
