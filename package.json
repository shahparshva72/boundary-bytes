{
  "name": "boundary-bytes",
  "version": "0.1.0",
  "scripts": {
    "dev": "bun --bun next dev --turbopack",
    "build": "bun --bun next build",
    "start": "bun --bun next start",
    "lint": "oxlint",
    "typecheck": "tsc --noEmit",
    "format": "oxfmt",
    "vercel-build": "bun --bun tsc --noEmit && bun --bun next build",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "oxfmt --check",
      "git add"
    ]
  },
  "dependencies": {
    "@tanstack/react-query": "^5.79.0",
    "@tanstack/react-query-devtools": "^5.79.0",
    "@vercel/analytics": "^1.5.0",
    "framer-motion": "^12.23.9",
    "ky": "^1.14.3",
    "lucide-react": "^1.7.0",
    "next": "^15.4.7",
    "nuqs": "^2.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-select": "^5.10.1",
    "react-spinners": "^0.17.0",
    "recharts": "^3.7.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.17.32",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.3",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.41.0",
    "tailwindcss": "^4",
    "typescript": "^5.8.3"
  }
}
