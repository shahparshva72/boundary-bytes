{
  "name": "boundary-bytes",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun --bun next dev --turbopack",
    "build": "bun --bun prisma generate && bun --bun next build",
    "start": "bun --bun next start",
    "lint": "oxlint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "postbuild": "prisma migrate deploy",
    "vercel-build": "prisma generate && prisma migrate deploy && next build",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "prettier --check",
      "git add"
    ]
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^2.0.67",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-query-devtools": "^5.96.2",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^1.6.1",
    "ai": "^5.0.170",
    "csv-parse": "^5.6.0",
    "framer-motion": "^12.38.0",
    "ky": "^1.14.3",
    "lucide-react": "^1.7.0",
    "next": "^15.5.14",
    "nuqs": "^2.8.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-select": "^5.10.2",
    "react-spinners": "^0.17.0",
    "recharts": "^3.8.1",
    "rss-parser": "^3.13.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.59.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prisma": "^7.7.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
